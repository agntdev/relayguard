[
  {
    "name": "/attach fails: OWNER_ID not configured",
    "steps": [
      {
        "send": { "text": "/attach" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "⚠️ /attach is not available — no owner configured. Set OWNER_ID in the environment." }
          }
        ]
      }
    ]
  },
  {
    "name": "/detach fails in private chat",
    "steps": [
      {
        "send": { "text": "/detach" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "⚠️ /detach must be used in the moderation group." }
          }
        ]
      }
    ]
  }
]